SCRUTATOR_DATABASE_URL=postgresql://scrutator:PASSWORD@localhost:5432/scrutator
SCRUTATOR_EMBEDDING_API_URL=http://localhost:8300
# API bind host (uvicorn). network_mode:host → this binds directly on the host interface.
#   Tier-2 (RECOMMENDED for prod): this host's Tailscale IP, e.g. 100.70.137.104 (arcana-kb) —
#     ingress is mesh-only by construction, no exposure justification needed.
#   Tier-1: 127.0.0.1 — loopback only; NOT reachable over the Tailscale mesh (breaks assistant/
#     connector integration). Use only for isolated local runs.
#   Tier-3: 0.0.0.0 — wildcard; requires an exposure justification (see Dockerfile). Public :8310
#     is firewall-closed on the prod host, so this is currently safe, but prefer Tier-2. INFRA-0120.
SCRUTATOR_HOST=0.0.0.0
SCRUTATOR_PORT=8310
SCRUTATOR_LTM_MC_URL=http://100.121.155.54:3900
SCRUTATOR_LTM_MC_API_KEY=
# LTM connector: openrouter (api, json_schema=true) is default after LTM-0009 pilot.
# CLI connectors (cursor/claude-code) lack json_schema and concurrency — slower and unreliable on repetitive content.
SCRUTATOR_LTM_CONNECTOR=openrouter
SCRUTATOR_LTM_MODEL=google/gemini-2.5-flash
# Dedicated POST /v1/ltm/ingest credential and comma-separated namespace scope.
# Do not reuse reader grants or SCRUTATOR_FEEDER_TOKEN.
SCRUTATOR_LTM_WRITER_TOKEN=
SCRUTATOR_LTM_WRITER_NAMESPACES=muneral
